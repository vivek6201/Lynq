{
  "name": "api",
  "projectType": "application",
  "sourceRoot": "apps/api",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "$(go env GOPATH)/bin/air -c .air.toml",
          "$(go env GOPATH)/bin/air -c .air.worker.toml"
        ],
        "parallel": true,
        "cwd": "apps/api"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o bin/api ./cmd/server",
        "cwd": "apps/api"
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy",
        "cwd": "apps/api"
      }
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run github.com/joho/godotenv/cmd/godotenv@latest -f .env atlas migrate diff schema_update --env local",
        "cwd": "apps/api"
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run github.com/joho/godotenv/cmd/godotenv@latest -f .env atlas migrate apply --env local",
        "cwd": "apps/api"
      }
    },
    "db:status": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run github.com/joho/godotenv/cmd/godotenv@latest -f .env atlas migrate status --env local",
        "cwd": "apps/api"
      }
    }
  }
}
